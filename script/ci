#!/usr/bin/env bash
# Run CI steps locally (no push). Same as .github/workflows/ci.yml Elixir job.
set -euo pipefail
cd "$(dirname "$0")/.."
echo "== mix deps.get"
mix deps.get
echo "== mix compile --warnings-as-errors"
mix compile --warnings-as-errors
echo "== mix format --check-formatted"
mix format --check-formatted
echo "== mix credo --strict"
mix credo --strict
echo "== mix sobelow"
mix sobelow --exit --skip
echo "== mix dialyzer"
mix dialyzer
echo "== mix test"
mix test
echo "== mix coveralls.html"
mix coveralls.html
echo "== mix docs"
mix docs --warninsg-as-errors
echo "== CI (local) passed"
